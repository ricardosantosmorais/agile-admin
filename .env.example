ADMIN_URL_API_V3=http://localhost:9001
AUTH_SESSION_SECRET=admin-v2-web-local-dev-secret
AUTH_COOKIE_SECURE=false
# Obrigatório para eventos server-side/edge irem para o Sentry.
SENTRY_DSN=
# Obrigatório para eventos do navegador irem para o Sentry.
NEXT_PUBLIC_SENTRY_DSN=
# Opcional: necessário apenas para upload de sourcemaps no build.
SENTRY_AUTH_TOKEN=
# Opcional: recomendado para separar development/staging/production.
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Opcional: 0 desliga tracing; usar valores baixos fora de desenvolvimento.
SENTRY_TRACES_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_DEBUG=false
NEXT_PUBLIC_SENTRY_DEBUG=false

# Playwright E2E
PLAYWRIGHT_AUTH_EMAIL=
PLAYWRIGHT_AUTH_PASSWORD=
PLAYWRIGHT_AUTH_CODE=
PLAYWRIGHT_PORT=3000
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Uploads / S3
UPLOAD_DRIVER=legacy
UPLOAD_S3_ACCESS_KEY_ID=
UPLOAD_S3_SECRET_ACCESS_KEY=
UPLOAD_S3_REGION=sa-east-1
# Bucket público é dinâmico por tenant no legado (`empresa.s3_bucket`).
UPLOAD_S3_PUBLIC_BUCKET=
# Bucket privado global usado por apps e uploads autenticados.
UPLOAD_S3_PRIVATE_BUCKET=agileecommerce-files
# URL base pública também é dinâmica por tenant no legado.
UPLOAD_S3_PUBLIC_BASE_URL=
